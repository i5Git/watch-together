# See config.ts for list of server config variables
# See src/config.ts for list of client config variables

# Leave blank to allow access to all features without login.
VITE_FIREBASE_CONFIG=
VITE_STRIPE_PUBLIC_KEY=
VITE_SERVER_HOST=
VITE_OAUTH_REDIRECT_HOSTNAME=

# Optional ICE/TURN configuration. Keep credentials out of source control.
VITE_TURN_SERVERS=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# Optional server configuration (see server/config.ts).
YOUTUBE_API_KEY=
FIREBASE_ADMIN_SDK_CONFIG=
DATABASE_URL=
REDIS_URL=
PORT=8080
HOST=0.0.0.0
